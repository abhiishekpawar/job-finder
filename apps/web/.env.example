NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Static login (no database)
AUTH_USERNAME="your-username"
AUTH_PASSWORD="your-password"
AUTH_SECRET="change-me-to-a-long-random-string"
APIFY_TOKEN=""
APIFY_INDEED_ACTOR_ID="misceres/indeed-scraper"
# LinkedIn: uses free guest API by default (no actor rental). Set APIFY_LINKEDIN_USE_APIFY=true to use Apify instead.
APIFY_LINKEDIN_ACTOR_ID="automation-lab/linkedin-jobs-scraper"
APIFY_NAUKRI_ACTOR_ID="jungle_synthesizer/naukri-com-scraper"
APIFY_OTHERS_ACTOR_ID="dp862/india-jobs-suite"
APIFY_SHINE_ACTOR_ID="automation-lab/shine-jobs-scraper"
APIFY_FOUNDIT_ACTOR_ID="easyapi/foundit-jobs-scraper"
APIFY_RUN_TIMEOUT_MS="60000"
DEFAULT_RESULTS_PER_SOURCE="25"
# AI resume checker — optional server fallback only (UI token field is preferred)
# Google Gemini (free): https://aistudio.google.com/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
# Groq (fast, free tier): https://console.groq.com/keys
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"
# OpenAI (paid fallback)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
